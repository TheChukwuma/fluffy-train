{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "fluffy-train API",
    "description": "Sample application APIs: public health, login (JWT), user profile, admin users.\n\n**Flow:** run **Login (alice)** or **Login (bob)** first; the Tests script stores `accessToken` in a collection variable for authenticated requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Public",
      "item": [
        {
          "name": "Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/public/health",
            "description": "No authentication required."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (alice — ROLE_USER)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    console.log('accessToken saved to collection variable');",
                  "} else {",
                  "    console.log('Login failed', pm.response.code);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"alice-secret\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Seeded user with ROLE_USER only. Saves JWT to `accessToken`."
          },
          "response": []
        },
        {
          "name": "Login (bob — ROLE_ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const data = pm.response.json();",
                  "    pm.collectionVariables.set('accessToken', data.accessToken);",
                  "    console.log('accessToken saved to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"bob\",\n  \"password\": \"bob-secret\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Seeded user with ROLE_USER and ROLE_ADMIN. Saves JWT to `accessToken`."
          },
          "response": []
        },
        {
          "name": "Login (wrong password)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Expect 401 with message \"Invalid username or password\"."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Me (GET)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/user/me",
            "description": "Requires valid JWT. Run a Login request first."
          },
          "response": []
        },
        {
          "name": "Me (POST)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": "{{baseUrl}}/api/user/me",
            "description": "Same handler as GET; optional empty JSON body."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List users",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/admin/users",
            "description": "Requires ROLE_ADMIN. Use **Login (bob)** first; with alice's token expect **403**."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Smoke",
      "item": [
        {
          "name": "Unknown path (expect 404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/no-such-endpoint",
            "description": "Should return 404, not 401."
          },
          "response": []
        }
      ]
    }
  ]
}
